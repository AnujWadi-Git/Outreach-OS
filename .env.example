DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/outreach_os?schema=public"

# NextAuth
AUTH_BYPASS_ENABLED="true"
STANDALONE_FRONTEND_ONLY="false"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
OWNER_EMAIL="enter your email"
LOCAL_AUTH_ENABLED="true"

# Google OAuth and Gmail API
# Set to true only after a valid Web application OAuth client is created.
GOOGLE_AUTH_ENABLED="false"
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4.1-mini"

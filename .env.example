# Example environment variables for local development
# Copy this to .env.local and fill in real values. DO NOT commit .env.local to git.

# Owner email used for owner-restricted flows (change to your email)
OWNER_EMAIL=you@example.com

# When true, the app skips OAuth and runs in the practical browser-first mode
NO_OAUTH_MODE=true

# NextAuth/dev host (if using next-auth)
NEXTAUTH_URL=http://localhost:3000

# Local development database (optional)
DATABASE_URL="file:./dev.db"
